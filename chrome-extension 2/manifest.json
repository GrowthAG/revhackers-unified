{
    "manifest_version": 3,
    "name": "RevNotes AI (by RevHackers)",
    "short_name": "RevNotes",
    "version": "2.1.0",
    "description": "OSINT Clipper e Meeting Recorder para o RevHackers Growth Hub. Grava reunioes do Google Meet e extrai dados de perfis LinkedIn.",
    "permissions": [
        "tabs",
        "activeTab",
        "storage",
        "scripting",
        "identity",
        "tabCapture",
        "desktopCapture",
        "offscreen",
        "notifications",
        "alarms"
    ],
    "host_permissions": [
        "https://meet.google.com/*",
        "https://www.linkedin.com/*",
        "https://*.supabase.co/*"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "RevHackers Clipper",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://meet.google.com/*"
            ],
            "js": [
                "content-meet.js"
            ],
            "run_at": "document_end"
        },
        {
            "matches": [
                "http://localhost:5173/*",
                "http://localhost:5174/*",
                "https://*.revhackers.com.br/*",
                "https://*.usefunnels.io/*",
                "https://*.revhackers.app/*"
            ],
            "js": [
                "content-hub.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.linkedin.com/in/*",
                "https://www.linkedin.com/company/*"
            ],
            "js": [
                "content-linkedin.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "popup/*",
                "icons/*",
                "offscreen.html"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
