{
  "manifest_version": 3,
  "name": "RevHackers Meet Recorder",
  "version": "1.0.0",
  "description": "Gravação de reuniões do Google Meet diretamente para o RevHackers Growth Hub (Supabase Storage).",
  "permissions": [
    "tabCapture",
    "activeTab",
    "offscreen",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gravar Reunião"
  }
}
